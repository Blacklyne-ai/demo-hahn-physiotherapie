---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';
---
<Layout title={`Impressum - ${site.name}`} noindex={true} current="/impressum">
  <section class="bg-cream pt-28 pb-12 md:pt-36 md:pb-16 border-b border-line">
    <div class="container-narrow">
      <span class="eyebrow mb-4">Rechtliches</span>
      <h1 class="display-2">Impressum</h1>
    </div>
  </section>
  <section class="bg-white sec-sm">
    <div class="container-narrow legal-prose">
      <h2>Angaben gemäß § 5 TMG</h2>
      <p>
        Carsten Hahn<br />
        Praxis für Physiotherapie Gesundheit und Prävention B.Sc. Carsten Hahn<br />
        Völklinger Str. 5<br />
        66346 Püttlingen
      </p>

      <h3>Weiterer Standort</h3>
      <p>St. Ingberter Straße 1<br />66583 Spiesen-Elversberg</p>

      <h2>Kontakt</h2>
      <p>
        Telefon: 06898 - 62191<br />
        Telefax: 06898 - 689862<br />
        E-Mail: <a href="mailto:info@hahn-physiotherapie.com">info@hahn-physiotherapie.com</a>
      </p>

      <h2>Aufsichtsbehörde</h2>
      <p>
        Ministerium für Arbeit, Soziales, Frauen und Gesundheit<br />
        Franz-Josef-Röder-Straße 23<br />
        66119 Saarbrücken<br />
        <a href="https://www.saarland.de/masfg/DE/home/home_node.html" target="_blank" rel="noopener">www.saarland.de/masfg</a>
      </p>

      <h2>Berufsbezeichnung und berufsrechtliche Regelungen</h2>
      <p>Berufsbezeichnung: Physiotherapeut (verliehen in der Bundesrepublik Deutschland)</p>

      <h3>Angaben zur Berufshaftpflichtversicherung</h3>
      <p>
        Name und Sitz des Versicherers:<br />
        Rehr und Jost GbR, Generalvertretung Allianz Versicherung<br />
        Vorderster Berg 1, 66333 Völklingen<br />
        Geltungsraum der Versicherung: Deutschland
      </p>

      <h2>Redaktionell verantwortlich</h2>
      <p>B.Sc. Carsten Hahn<br />Völklinger Str. 5<br />66346 Püttlingen</p>

      <h2>EU-Streitschlichtung</h2>
      <p>
        Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
        <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener">https://ec.europa.eu/consumers/odr/</a>.
        Unsere E-Mail-Adresse finden Sie oben im Impressum.
      </p>

      <h2>Verbraucherstreitbeilegung / Universalschlichtungsstelle</h2>
      <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>

      <h2>Bildnachweis</h2>
      <p>Logo und Portrait Carsten Hahn: eigene Darstellung. Weitere Fotos: Pexels (lizenzfrei).</p>
    </div>
  </section>
</Layout>
