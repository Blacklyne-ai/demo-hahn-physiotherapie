---
import { site, footerNav, legalNav, standorte, mailLink } from '../data/site';
import Icon from './Icon.astro';
const year = 2026;
---
<footer class="section-dark on-dark relative overflow-hidden" role="contentinfo" style="background: rgb(var(--rgb-dark-deep));">
  <div class="container-px relative pt-16 md:pt-20 pb-24 lg:pb-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-10 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="lg:col-span-4">
        <a href="/" aria-label={`${site.name} - Startseite`} class="inline-block">
          <img src="/logo-light.png" alt="Hahn Physiotherapie" width="230" height="40" class="h-10 w-auto" loading="lazy" />
        </a>
        <p class="text-white/60 text-[0.95rem] leading-relaxed mt-6 max-w-xs text-pretty">
          Praxis für Physiotherapie, Gesundheit und Prävention von Carsten Hahn (B.Sc.) -
          mit dem L.I.G.H.T.-Konzept aus der Erfahrung des Leistungssports.
        </p>
        <div class="flex items-center gap-3 mt-7">
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="social-ico">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="social-ico">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3l.5-3H14V4.5c0-.8.3-1.5 1.5-1.5H17V.2C16.7.1 15.6 0 14.4 0 11.9 0 10 1.5 10 4.3V6H7v3h3v9h4V9Z"/></svg>
          </a>
          <a href={site.social.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" class="social-ico">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0-.02-5ZM3 9h4v12H3V9Zm6 0h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95C20.6 8.75 22 11 22 14.4V21h-4v-5.8c0-1.4-.03-3.2-1.95-3.2-1.96 0-2.26 1.5-2.26 3.1V21H9V9Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Praxis -->
      <div class="lg:col-span-2">
        <h3 class="text-white text-[0.74rem] font-semibold uppercase tracking-[0.16em] mb-5">Praxis</h3>
        <ul class="space-y-2.5 text-[0.92rem]">
          {footerNav.praxis.map((l) => (<li><a href={l.href} class="text-white/60 hover:text-white transition">{l.label}</a></li>))}
        </ul>
      </div>

      <!-- Leistungen -->
      <div class="lg:col-span-3">
        <h3 class="text-white text-[0.74rem] font-semibold uppercase tracking-[0.16em] mb-5">Leistungen</h3>
        <ul class="space-y-2.5 text-[0.92rem]">
          {footerNav.leistungen.map((l) => (<li><a href={l.href} class="text-white/60 hover:text-white transition">{l.label}</a></li>))}
        </ul>
      </div>

      <!-- Kontakt -->
      <div class="lg:col-span-3">
        <h3 class="text-white text-[0.74rem] font-semibold uppercase tracking-[0.16em] mb-5">Kontakt</h3>
        <ul class="space-y-4 text-[0.92rem] text-white/60">
          {standorte.map((s) => (
            <li>
              <p class="text-white/85 font-medium mb-0.5">{s.short}</p>
              <p>{s.street}, {s.postcode} {s.city}</p>
              <a href={`tel:${s.phoneIntl}`} class="inline-flex items-center gap-2 mt-1 hover:text-white transition">
                <Icon name="Phone" size={14} strokeWidth={2} class="text-blue-bright" />{s.phoneDisplay}
              </a>
            </li>
          ))}
          <li>
            <a href={mailLink} class="inline-flex items-center gap-2 hover:text-white transition break-all">
              <Icon name="Mail" size={14} strokeWidth={2} class="text-blue-bright" />{site.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Legal bar -->
    <div class="pt-7 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <p class="text-white/55 text-[0.82rem] text-pretty">
        © {year} {site.legal.businessName} · {site.legal.street}, {site.legal.postcode} {site.legal.city}
      </p>
      <div class="flex items-center gap-5 text-[0.85rem]">
        {legalNav.map((l) => (<a href={l.href} class="text-white/60 hover:text-white transition">{l.label}</a>))}
      </div>
    </div>
  </div>
</footer>

<style>
  .social-ico { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 999px; color: rgba(255,255,255,0.78); background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14); transition: all 0.25s ease; }
  .social-ico:hover { color: #fff; background: rgba(92,178,226,0.18); border-color: rgba(92,178,226,0.5); transform: translateY(-2px); }
</style>
